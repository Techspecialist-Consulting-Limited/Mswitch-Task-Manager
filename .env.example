# ──────────────────────────────────────────────
# Required — app will not start without these
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
AUTH_SECRET=generate-a-long-random-secret-using-openssl-rand-base64-32
APP_URL=https://your-app.vercel.app

# ──────────────────────────────────────────────
# File storage — required for uploads to work
# Create a Blob store in your Vercel dashboard
# (Storage → Create → Blob) then copy the token
# ──────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ──────────────────────────────────────────────
# Email — at least one required for password resets
# ──────────────────────────────────────────────

# Option A: Resend (recommended — free tier: 100 emails/day)
# Get a free API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Option B: SMTP (Gmail, SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM=TaskFlow <noreply@yourdomain.com>
