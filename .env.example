# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
AUTH_SECRET=generate-a-long-random-secret-using-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Email — optional, at least one for password resets to work
# Option A: Resend (recommended — free tier: 100 emails/day)
# Get a free API key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Option B: SMTP (Gmail, SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM=TaskFlow <noreply@yourdomain.com>
